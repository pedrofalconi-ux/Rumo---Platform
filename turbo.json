{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "GEMINI_API_KEY",
        "LLM_MAX_TOKENS",
        "LLM_MODEL",
        "LLM_PROVIDER",
        "LLM_TEMPERATURE",
        "SESSION_SECRET",
        "SUPABASE_SERVICE_ROLE_KEY"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
